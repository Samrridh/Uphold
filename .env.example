# --- Local: PEM files ---
PRIVATE_KEY_PATH=keys/private.pem
PUBLIC_KEY_PATH=keys/public.pem

# --- Vercel: name must match exactly (case-sensitive) ---
# Option A — paste full PEM (multi-line is OK in Vercel’s value box):
# PRIVATE_KEY_PEM=
# PUBLIC_KEY_PEM=

# Option B — most reliable: base64 of the entire .pem file (no newline issues).
# PowerShell (private):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("keys/private.pem"))
# PowerShell (public):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("keys/public.pem"))
# PRIVATE_KEY_PEM_B64=
# PUBLIC_KEY_PEM_B64=

# Optional database override (Vercel default is sqlite in /tmp if unset)
# DATABASE_URL=

# After changing env vars on Vercel: redeploy (or “Redeploy” latest) so the runtime picks them up.
